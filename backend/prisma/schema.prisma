// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String         @id @default(uuid())
  studentId      String         @unique
  name           String
  avatarUrl      String?
  telegramHandle String?
  karma          Int            @default(0)
  listings       Listing[]
  threads        ForumThread[]
  comments       Comment[]
  votes          Vote[]
  bookmarks      Bookmark[]
  notifications  Notification[]
  createdAt      DateTime       @default(now())
}

model Listing {
  id          String        @id @default(uuid())
  title       String
  description String
  price       Float?
  type        ListingType
  category    String
  authorId    String
  author      User          @relation(fields: [authorId], references: [id])
  images      String[]
  status      ListingStatus @default(active)
  comments    Comment[]
  votes       Vote[]
  bookmarks   Bookmark[]
  createdAt   DateTime      @default(now())
}

model ForumThread {
  id         String    @id @default(uuid())
  title      String
  body       String
  authorId   String
  author     User      @relation(fields: [authorId], references: [id])
  category   String
  replyCount Int       @default(0) @map("replyCount")
  upvotes    Int       @default(0)
  isPinned   Boolean   @default(false) @map("isPinned")
  createdAt  DateTime  @default(now())
  comments   Comment[]
  votes      Vote[]

  @@map("ForumThread")
}

model Comment {
  id        String       @id @default(uuid())
  body      String
  authorId  String
  author    User         @relation(fields: [authorId], references: [id])
  listingId String?
  listing   Listing?     @relation(fields: [listingId], references: [id])
  threadId  String?
  thread    ForumThread? @relation(fields: [threadId], references: [id])
  parentId  String?
  parent    Comment?     @relation("replies", fields: [parentId], references: [id])
  replies   Comment[]    @relation("replies")
  votes     Vote[]
  createdAt DateTime     @default(now())

  @@map("Comment")
}

model Vote {
  id        String       @id @default(uuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  listingId String?
  listing   Listing?     @relation(fields: [listingId], references: [id])
  threadId  String?
  thread    ForumThread? @relation(fields: [threadId], references: [id])
  commentId String?
  comment   Comment?     @relation(fields: [commentId], references: [id])
  value     Int
  createdAt DateTime     @default(now())

  @@map("Vote")
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@map("Bookmark")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false) @map("isRead")
  relatedId String?
  createdAt DateTime @default(now())

  @@map("Notification")
}

model Whitelist {
  studentId String  @id @map("student_id")
  name      String
  groupCode String  @map("group_code")
  isActive  Boolean @default(true) @map("is_active")

  @@map("whitelist")
}

enum ListingType {
  sell
  buy
  service
  lost
  found
}

enum ListingStatus {
  active
  closed
  archived
}
